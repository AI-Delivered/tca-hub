# Supabase — create a project at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — get key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used for text embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Firecrawl — get key at firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# Secret to protect manual crawl trigger (generate any random string)
CRAWL_SECRET=your-random-secret

# Crawl target
CRAWL_TARGET_URL=https://www.tcatitans.org
